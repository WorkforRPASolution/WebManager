# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection
# EARS: Shared database with Akka server
MONGODB_URI=mongodb://localhost:27017/EARS

# WEB_MANAGER: WebManager exclusive database
WEBMANAGER_DB_URI=mongodb://localhost:27017/WEB_MANAGER

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Security Settings
BCRYPT_SALT_ROUNDS=12
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# ManagerAgent RPC Settings (Client control via Avro RPC)
MANAGER_AGENT_PORT=7180
SOCKS_PROXY_PORT=30000

# FTP Settings (ManagerAgent FTP Server, 기본 포트 7181)
FTP_PORT=7181
FTP_USER=ARS
FTP_PASS=ars2015!
FTP_TIMEOUT=30000

# Image Storage Settings
# 'httpwebserver' = MongoDB direct storage (EMAIL_IMAGE_REPOSITORY, required for Email Image page)
# 'local' = Local file system storage (legacy, does NOT support Email Image page filtering/pagination)
IMAGE_STORAGE=httpwebserver
# Maximum image file size in MB (default: 5)
IMAGE_MAX_FILE_SIZE_MB=5

# Config file paths (relative to FTP home directory)
CONFIG_FILE_1_NAME=Main Config
CONFIG_FILE_1_PATH=/config/main.json
CONFIG_FILE_2_NAME=Process Config
CONFIG_FILE_2_PATH=/config/process.json
CONFIG_FILE_3_NAME=Network Config
CONFIG_FILE_3_PATH=/config/network.json
CONFIG_FILE_4_NAME=Schedule Config
CONFIG_FILE_4_PATH=/config/schedule.json

# Operation Mode (standalone | integrated)
# standalone: Admin approves reset, shares temp password manually (default)
# integrated: User requests reset with email, temp password sent automatically
OPERATION_MODE=standalone

# Redis Connection (Agent Status + MetaInfo, DB 0 - optional, graceful degradation)
# Simple mode:
REDIS_URL=redis://localhost:6379/0
# Sentinel mode:
# REDIS_URL={sentinel1:26379},{sentinel2:26379},{sentinel3:26379}#mymaster
# REDIS_PASSWORD=your-redis-password

# EARS InterfaceServer (integrated 모드에서 사용자 검색 + 이메일 조회)
# EARS_INTERFACE_URL=http://10.0.0.1:8080
