# Backend API URL (필수)
# 개발 모드: 프론트엔드(5173)와 백엔드(3000) 분리 실행 시
VITE_API_URL=http://localhost:3000/api

# 원격 서버 접속 시 서버 IP로 변경
# VITE_API_URL=http://서버IP:3000/api

# AccessLog log_type 신규 이름 적용 기준 Agent 버전 (X.X.X.X 형식)
# 이 버전 이상의 Agent는 canonical 이름 사용, 미만 또는 버전 불명 시 oldName 사용
# VITE_NEW_LOG_TYPE_THRESHOLD=20.0.0.0
